{
     "name": "usuario/mi-laravel-app",
     "description": "Aplicación Laravel lista para Render con Docker",
     "type": "project",
     "require": {
          "php": "^8.2",
          "laravel/framework": "^10.0",
          "guzzlehttp/guzzle": "^7.0.1",
          "monolog/monolog": "^3.0",
          "ext-pdo": "*",
          "ext-mbstring": "*",
          "ext-openssl": "*"
     },
     "require-dev": {
          "fakerphp/faker": "^1.9.1",
          "phpunit/phpunit": "^10.0",
          "laravel/sail": "^1.0.1"
     },
     "autoload": {
          "psr-4": {
               "App\\": "app/"
          }
     },
     "autoload-dev": {
          "psr-4": {
               "Tests\\": "tests/"
          }
     },
     "scripts": {
          "post-root-package-install": [
               "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
          ],
          "post-create-project-cmd": [
               "@php artisan key:generate"
          ],
          "post-install-cmd": [
               "@php artisan migrate --force"
          ]
     },
     "config": {
          "optimize-autoloader": true,
          "preferred-install": "dist",
          "sort-packages": true
     }
}